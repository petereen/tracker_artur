# Прогон unit-тестов в облаке (az acr build). Падение pytest => падение сборки.
FROM python:3.11-slim

WORKDIR /app

RUN apt-get update && apt-get install -y --no-install-recommends gcc libpq-dev && rm -rf /var/lib/apt/lists/*

COPY requirements.txt .
RUN pip install --no-cache-dir -r requirements.txt pytest

COPY . .

ENV DATABASE_URL=postgresql+asyncpg://u:p@localhost/db \
    SYNC_DATABASE_URL=postgresql+psycopg2://u:p@localhost/db \
    SECRET_KEY=test-secret \
    BOT_TOKEN=test-token-123:ABC

RUN python -m pytest -q
